# Normalize line endings to LF on commit (Windows-friendly)
* text=auto eol=lf

# Binary files — no line ending normalization
*.png binary
*.jpg binary
*.jpeg binary
*.gif binary
*.webp binary
*.ico binary
*.svg text eol=lf
*.woff binary
*.woff2 binary
*.ttf binary
*.eot binary

# SQLite DB — binary
*.sqlite binary
*.sqlite-wal binary
*.sqlite-shm binary
