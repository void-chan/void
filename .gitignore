# ═══════════════════════════════════════════════════════════════════
#  .gitignore  —  Local-first, security-focused project
#  WHY: Prevent secrets, databases, and build artifacts from
#       being committed — especially important for a private repo.
# ═══════════════════════════════════════════════════════════════════

# ── Dependencies ──────────────────────────────────────────────────
node_modules/
.pnp/
.pnp.js

# ── Environment / Secrets ─────────────────────────────────────────
# NEVER commit .env — it contains real secrets
.env
.env.local
.env.production
.env.*.local
# Commit .env.example (template with no real values) ← checked in

# ── Database (LOCAL ONLY) ─────────────────────────────────────────
# WHY: SQLite file contains real user data — never commit it
backend/storage/database.sqlite
backend/storage/database.sqlite-wal
backend/storage/database.sqlite-shm

# ── Uploaded files ────────────────────────────────────────────────
# WHY: User-uploaded files should never go into git
backend/storage/uploads/*
# Allow the .gitkeep placeholder to be tracked
!backend/storage/uploads/.gitkeep

# ── Build output ──────────────────────────────────────────────────
dist/
build/
.output/
frontend/dist/

# ── Logs ──────────────────────────────────────────────────────────
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*
logs/

# ── OS generated ──────────────────────────────────────────────────
.DS_Store
.DS_Store?
._*
.Spotlight-V100
.Trashes
ehthumbs.db
Thumbs.db
desktop.ini

# ── IDEs ──────────────────────────────────────────────────────────
.vscode/settings.json
.vscode/launch.json
.idea/
*.suo
*.ntvs*
*.njsproj
*.sln
*.sw?

# ── Testing ───────────────────────────────────────────────────────
coverage/
.nyc_output/

# ── Misc ──────────────────────────────────────────────────────────
.cache/
.parcel-cache/
.turbo/
