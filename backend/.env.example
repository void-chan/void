# ─── Server ────────────────────────────────────────────
PORT=4000
NODE_ENV=development
HOST=localhost

# ─── Database ──────────────────────────────────────────
# Path is relative to backend root
DB_PATH=./storage/database.sqlite

# ─── JWT ───────────────────────────────────────────────
# Generate with: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=CHANGE_THIS_TO_A_LONG_RANDOM_STRING_MINIMUM_64_CHARACTERS
JWT_EXPIRES_IN=15m
JWT_REFRESH_SECRET=CHANGE_THIS_REFRESH_SECRET_ALSO_LONG_AND_RANDOM
JWT_REFRESH_EXPIRES_IN=7d

# ─── Cookie ────────────────────────────────────────────
COOKIE_SECURE=false           # Set to true in production (requires HTTPS)
COOKIE_SAME_SITE=strict

# ─── CORS ──────────────────────────────────────────────
CORS_ORIGIN=http://localhost:5173

# ─── Upload ────────────────────────────────────────────
UPLOAD_MAX_SIZE_MB=10
UPLOAD_DIR=./storage/uploads

# ─── Rate Limiting ─────────────────────────────────────
RATE_LIMIT_WINDOW_MS=900000   # 15 minutes
RATE_LIMIT_MAX=100
AUTH_RATE_LIMIT_MAX=10        # Stricter limit on auth endpoints

# ─── Bcrypt ────────────────────────────────────────────
BCRYPT_ROUNDS=12
