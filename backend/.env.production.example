# ── Railway Production Environment Variables ────────────────────────────────
# Copy these into Railway dashboard → your service → Variables
# DO NOT commit real values — this file is just a reference template

PORT=4000
NODE_ENV=production
HOST=0.0.0.0

# Railway mounts the persistent volume at /data by default
# Set this to wherever you configure your Railway volume mount path
DB_PATH=/data/database.sqlite

# Generate strong secrets:
# node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=REPLACE_WITH_64_CHAR_RANDOM_HEX
JWT_EXPIRES_IN=15m
JWT_REFRESH_SECRET=REPLACE_WITH_DIFFERENT_64_CHAR_RANDOM_HEX
JWT_REFRESH_EXPIRES_IN=7d
JWT_ISSUER=yourdomain.com
JWT_AUDIENCE=yourdomain.com-client

COOKIE_SECURE=true
COOKIE_SAME_SITE=strict

# Your Vercel frontend URL (no trailing slash)
CORS_ORIGIN=https://your-app.vercel.app

UPLOAD_MAX_SIZE_MB=10
UPLOAD_DIR=/data/uploads

RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX=100
AUTH_RATE_LIMIT_MAX=10
BCRYPT_ROUNDS=12

TRUST_PROXY=1

# ── Admin seed (only needed when running npm run db:seed) ─────────────────────
ADMIN_USERNAME=void
ADMIN_PASSWORD=REPLACE_WITH_STRONG_PASSWORD
# Pre-computed bcrypt hash of your admin phrase — never store plaintext
ADMIN_PHRASE_HASH=REPLACE_WITH_YOUR_BCRYPT_HASH
